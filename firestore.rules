// firestore.rules
// Copia esto en Firebase Console → Firestore → Reglas

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Clientes: el propio cliente puede leer y actualizar su doc, admins pueden todo
    match /clientes/{clienteId} {
      allow read: if request.auth != null || resource.data.id == clienteId;
      allow create: if true;
      allow update: if true;
      allow delete: if request.auth != null;
    }

    // Visitas: solo admins autenticados
    match /visitas/{visitaId} {
      allow read, write: if request.auth != null;
    }

    // Canjes: solo admins autenticados
    match /canjes/{canjeId} {
      allow read, write: if request.auth != null;
    }

    // Config: solo superadmin
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'administrador@dpoyo.cl';
    }
  }
}
